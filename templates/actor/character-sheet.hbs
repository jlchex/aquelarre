        </section>

        <section class="card">
          <h2>Equipo transportado</h2>
          <textarea name="system.inventory.carriedEquipment">{{system.inventory.carriedEquipment}}</textarea>
        </section>

        <section class="card">
          <h2>Hechizos y notas</h2>
          <textarea name="system.magic.spellsNotes">{{system.magic.spellsNotes}}</textarea>
        </section>

        <section class="card">
          <h2>Rituales y notas</h2>
          <textarea name="system.magic.ritualsNotes">{{system.magic.ritualsNotes}}</textarea>
        </section>

        <section class="card">
          <h2>Descripción</h2>
          <textarea name="system.bio.description">{{system.bio.description}}</textarea>
        </section>

        <section class="card">
          <h2>Historia</h2>
          <textarea name="system.bio.history">{{system.bio.history}}</textarea>
        </section>
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="referencia">
