<form class="aquelarre-sheet flexcol" autocomplete="off">
  <header class="sheet-header">
    <div class="header-main">
      <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
      <div class="header-fields">
        <h1 class="charname">
          <input name="name" type="text" value="{{actor.name}}" placeholder="Nombre del personaje" />
        </h1>

        <div class="bio-grid">
          <label>Reino
            <select name="system.creation.kingdom" data-creation-kingdom>
              <option value="">--</option>
              {{#each kingdomOptions as |opt|}}
                <option value="{{opt.[0]}}" {{#if (eq ../system.creation.kingdom opt.[0])}}selected{{/if}}>
                  {{opt.[1]}}
                </option>
              {{/each}}
            </select>
          </label>

          <label>Grupo étnico
            <select name="system.creation.ethnicityKey" data-creation-ethnicity>
              <option value="">--</option>
              {{#each ethnicityOptions as |opt|}}
                <option value="{{opt.[0]}}" {{#if (eq ../system.creation.ethnicityKey opt.[0])}}selected{{/if}}>
                  {{opt.[1]}}
                </option>
              {{/each}}
            </select>
          </label>

          <label>Clase social
            <select name="system.creation.socialClassKey" data-creation-social-class>
              <option value="">--</option>
              {{#each socialClassOptions as |opt|}}
                <option value="{{opt.[0]}}" {{#if (eq ../system.creation.socialClassKey opt.[0])}}selected{{/if}}>
                  {{opt.[1]}}
                </option>
              {{/each}}
            </select>
          </label>

          <label>Sociedad
            <input type="text" value="{{creationSocietyLabel}}" disabled />
          </label>

          <label>Profesión
            <input type="text" value="{{system.bio.profession}}" disabled />
          </label>

          <label>Sexo
            <select name="system.bio.sex">
              <option value="">--</option>
              <option value="male" {{#if (eq system.bio.sex "male")}}selected{{/if}}>Hombre</option>
              <option value="female" {{#if (eq system.bio.sex "female")}}selected{{/if}}>Mujer</option>
            </select>
          </label>

          <label>Edad
            <input type="text" name="system.bio.age" value="{{system.bio.age}}" />
          </label>
        </div>
      </div>
    </div>
  </header>

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="creation">Creación</a>
    <a class="item" data-tab="summary">Resumen</a>
    <a class="item" data-tab="skills">Competencias</a>
    <a class="item" data-tab="combat">Combate</a>
    <a class="item" data-tab="inventory">Inventario</a>
    <a class="item" data-tab="magic">Magia y notas</a>
    <a class="item" data-tab="reference">Referencia</a>
  </nav>

  <section class="sheet-body">
    <div class="tab" data-group="primary" data-tab="creation">
      <section class="card">
        <h2>Creación RAW</h2>

        <div class="button-row">
          <button type="button" data-generate-characteristics="true">Tirar características</button>
          <button type="button" data-randomize-origin="true">Origen aleatorio</button>
          <button type="button" data-generate-backstory="true">Generar trasfondo</button>
        </div>

        <div class="combat-grid creation-profession-grid">
          <label>
            <span>Profesión paterna</span>
            <select name="system.creation.fatherProfessionKey" data-creation-father-profession>
              <option value="">--</option>
              {{#each fatherProfessionOptions as |opt|}}
                <option value="{{opt.key}}" {{#if (eq ../system.creation.fatherProfessionKey opt.key)}}selected{{/if}}>
                  {{opt.label}}
                </option>
              {{/each}}
            </select>
          </label>

          <label class="aq-field-with-tooltip">
            <span class="aq-label-with-tooltip">
              <span>Profesión RAW</span>

              {{#if selectedProfession}}
                {{#unless selectedProfession.valid}}
  <p><strong>Motivos:</strong> {{selectedProfession.reasonText}}</p>
{{/unless}}

                 <span
                    class="aq-tooltip-trigger"
                    tabindex="0"
                      data-tooltip="{{#if selectedProfession.valid}}La profesión cumple los requisitos actuales.{{else}}{{selectedProfession.reasonText}}{{/if}}">
                   ⓘ 
                  </span>
              {{/if}}
            </span>

            <select name="system.creation.professionKey" data-creation-profession>
<option value="">--</option>
{{#each professionOptions as |opt|}}
  <option
    value="{{opt.key}}"
    {{#if (eq ../system.creation.professionKey opt.key)}}selected{{/if}}>
    {{opt.label}}{{#unless opt.valid}} — bloqueada{{/unless}}
  </option>
{{/each}}
</select>
          </label>
        </div>

        <p><strong>Bonos por profesión paterna:</strong> {{#if fatherProfessionBonusText}}{{fatherProfessionBonusText}}{{else}}Sin bonificadores{{/if}}</p>

        <p><strong>Profesiones válidas:</strong> {{validProfessionsText}}</p>

        {{#if invalidProfessionHints.length}}
          <div class="creation-hints">
            <p><strong>Bloqueos actuales:</strong></p>
            <ul>
              {{#each invalidProfessionHints as |hint|}}
                <li>{{hint}}</li>
              {{/each}}
            </ul>
          </div>
        {{/if}}

        {{#if selectedProfession}}
          <div class="profession-panel {{#if selectedProfession.valid}}profession-panel--ok{{else}}profession-panel--blocked{{/if}}">
            <div class="profession-panel__header">
              <h3>{{selectedProfession.label}}</h3>

              <div class="profession-badges">
                {{#each selectedProfessionBadges as |badge|}}
                  <span
                    class="profession-badge profession-badge--{{badge.type}} {{#if badge.tooltip}}aq-tooltip-badge{{/if}}"
                    {{#if badge.tooltip}}data-tooltip="{{badge.tooltip}}"{{/if}}>
                    {{badge.label}}
                  </span>
                {{/each}}
              </div>
            </div>

            <p>
              <strong>Estado:</strong>
              {{#if selectedProfession.valid}}Disponible{{else}}Bloqueada{{/if}}
            </p>

            {{#unless selectedProfession.valid}}
              <p><strong>Motivos:</strong> {{selectedProfession.reasonText}}</p>
            {{/unless}}

            <div class="profession-panel__grid">
              <div class="card-subsection">
                <h4>Requisitos</h4>

                <p>
                  <strong>Sociedad:</strong>
                  <span
                    class="{{#if selectedProfession.valid}}aq-requirement-ok{{else}}aq-tooltip-badge{{/if}}"
                    {{#unless selectedProfession.valid}}data-tooltip="{{selectedProfession.reasonText}}"{{/unless}}>
                    {{#if selectedProfession.society.length}}
                      {{selectedProfession.society}}
                    {{else}}
                      Cualquiera
                    {{/if}}
                  </span>
                </p>

                <p>
                  <strong>Clase social:</strong>
                  <span
                    class="{{#if selectedProfession.valid}}aq-requirement-ok{{else}}aq-tooltip-badge{{/if}}"
                    {{#unless selectedProfession.valid}}data-tooltip="{{selectedProfession.reasonText}}"{{/unless}}>
                    {{#if selectedProfession.socialClass.length}}
                      {{selectedProfession.socialClass}}
                    {{else}}
                      Cualquiera
                    {{/if}}
                  </span>
                </p>

                <p>
                  <strong>Reinos:</strong>
                  <span
                    class="{{#if selectedProfession.valid}}aq-requirement-ok{{else}}aq-tooltip-badge{{/if}}"
                    {{#unless selectedProfession.valid}}data-tooltip="{{selectedProfession.reasonText}}"{{/unless}}>
                    {{#if selectedProfession.kingdoms.length}}
                      {{selectedProfession.kingdoms}}
                    {{else}}
                      Cualquiera
                    {{/if}}
                  </span>
                </p>

                <p>
                  <strong>Sexo:</strong>
                  <span
                    class="{{#if selectedProfession.valid}}aq-requirement-ok{{else}}aq-tooltip-badge{{/if}}"
                    {{#unless selectedProfession.valid}}data-tooltip="{{selectedProfession.reasonText}}"{{/unless}}>
                    {{#if selectedProfession.sex.length}}
                      {{#each selectedProfession.sex as |sx|}}
                        {{#if (eq sx "male")}}
                          Hombre
                        {{else}}
                          {{#if (eq sx "female")}}
                            Mujer
                          {{else}}
                            {{sx}}
                          {{/if}}
                        {{/if}}
                      {{/each}}
                    {{else}}
                      Cualquiera
                    {{/if}}
                  </span>
                </p>
              </div>

              <div class="card-subsection">
                <h4>Mínimos</h4>
                {{#if selectedProfession.minStats.length}}
                  <div class="profession-stats">
                    {{#each selectedProfession.minStats as |stat|}}
                      <div
                        class="profession-stat {{#if stat.ok}}profession-stat--ok{{else}}profession-stat--fail aq-tooltip-badge{{/if}}"
                        {{#unless stat.ok}}data-tooltip="No cumple el mínimo de {{stat.label}}: necesita {{stat.required}} y tiene {{stat.current}}"{{/unless}}>
                        <span class="profession-stat__label">{{stat.label}}</span>
                        <span class="profession-stat__values">{{stat.current}} / {{stat.required}}</span>
                      </div>
                    {{/each}}
                  </div>
                {{else}}
                  <p>Sin mínimos especiales.</p>
                {{/if}}
              </div>
            </div>

            <div class="profession-panel__grid">
              <div class="card-subsection">
                <h4>Ventajas de creación</h4>
                <p><strong>Puntos de competencia:</strong> {{selectedProfession.skillPoints}}</p>
                <p><strong>Dinero:</strong> {{selectedProfession.money}}</p>
              </div>

              <div class="card-subsection">
                <h4>Competencias permitidas</h4>
                {{#if selectedProfession.allowedSkills.length}}
                  <div class="profession-skill-tags">
                    {{#each selectedProfession.allowedSkills as |skill|}}
                      <span class="profession-badge profession-badge--skill">{{skill}}</span>
                    {{/each}}
                  </div>
                {{else}}
                  <p>No definidas.</p>
                {{/if}}
              </div>
            </div>
          </div>
        {{/if}}

        <div class="button-row">
<button
  type="button"
  data-apply-profession-raw="true"
  {{#if selectedProfession}}
    {{#unless selectedProfession.valid}}disabled{{/unless}}
  {{else}}
    disabled
  {{/if}}>
  Aplicar profesión RAW
</button>
</div>
        <div class="skill-points-summary">
          <div class="skill-points-box">
            <span class="label">Totales</span>
            <span class="value">{{skillPointSummary.total}}</span>
          </div>
          <div class="skill-points-box">
            <span class="label">Gastados</span>
            <span class="value">{{skillPointSummary.spent}}</span>
          </div>
          <div class="skill-points-box skill-points-box--remaining">
            <span class="label">Restantes</span>
            <span class="value">{{skillPointSummary.remaining}}</span>
          </div>
        </div>

        <p><strong>Competencias permitidas:</strong> {{allowedSkillsText}}</p>

        {{#if skillInvestmentBreakdown.length}}
          <div class="skill-breakdown-panel">
            <p><strong>Desglose de gasto:</strong></p>
            <div class="skill-breakdown-tags">
              {{#each skillInvestmentBreakdown as |entry|}}
                <span class="skill-breakdown-tag" title="{{entry.label}}: invertido {{entry.invested}}, total {{entry.total}}">
                  {{entry.label}}: {{entry.spent}}
                </span>
              {{/each}}
            </div>
          </div>
        {{/if}}
      </section>
    </div>

    <div class="tab" data-group="primary" data-tab="summary">
      <div class="sheet-grid sheet-grid--summary">
        <section class="card">
          <h2>Características</h2>
          <div class="characteristics-grid">
            {{#each system.characteristics as |char key|}}
              <div class="stat-box">
                <label>{{char.label}}</label>
                <input type="number" name="system.characteristics.{{key}}.value" value="{{char.value}}" />
                <button type="button" data-roll-characteristic="{{key}}">🎲</button>
              </div>
            {{/each}}
          </div>
        </section>

        <section class="card">
          <h2>Secundarias</h2>
          <div class="secondary-grid">
            <label>Suerte <input type="number" name="system.secondary.luck.value" value="{{system.secondary.luck.value}}" disabled /></label>
            <label>Suerte actual <input type="number" name="system.secondary.luckCurrent.value" value="{{system.secondary.luckCurrent.value}}" /></label>
            <label>Templanza <input type="number" name="system.secondary.temperance.value" value="{{system.secondary.temperance.value}}" /></label>
            <label>RR <input type="number" name="system.secondary.rr.value" value="{{system.secondary.rr.value}}" /></label>
            <label>IRR <input type="number" name="system.secondary.irr.value" value="{{system.secondary.irr.value}}" /></label>
            <label>PF <input type="number" name="system.secondary.pf.value" value="{{system.secondary.pf.value}}" /></label>
            <label>PC <input type="number" name="system.secondary.pc.value" value="{{system.secondary.pc.value}}" /></label>
            <label>PV actuales <input type="number" name="system.secondary.pv.value" value="{{system.secondary.pv.value}}" /></label>
            <label>PV máximos <input type="number" name="system.secondary.pv.max" value="{{system.secondary.pv.max}}" disabled /></label>
          </div>

          <div class="status-effects">
            <h3>Estados</h3>

            {{#if displayStatusEffects.length}}
              {{#each displayStatusEffects}}
                <div class="status-effect">
                  <strong>{{this.label}}</strong> ({{this.locationLabel}}){{#if this.durationLabel}} - {{this.durationLabel}}{{/if}}{{#if this.notes}} - {{this.notes}}{{/if}}
                </div>
              {{/each}}
            {{else}}
              <p>Sin efectos</p>
            {{/if}}
          </div>
        </section>
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="skills">
      <div class="skills-layout">
        <section class="card">
          <h2>Competencias Generales</h2>

          <div class="skills-card-body">
            <div class="skills-table">
              <div class="skills-head skills-grid-extended">
                <span class="skill-head-name">Competencia</span>
                <span>Base</span>
                <span>Total</span>
                <span>Máx.</span>
                <span>Ajuste</span>
                <span>Acciones</span>
              </div>

              {{#each generalSkills as |skill|}}
                <div class="skills-row skills-grid-extended {{skill.rowClasses}}" title="{{skill.rowTooltip}}">
                  <span class="skill-name">
                    <span class="skill-label">{{skill.label}}</span>
                    <span class="skill-meta">
                      {{#if skill.allowed}}
                        <small class="skill-tag skill-tag--allowed">permitida</small>
                      {{else}}
                        <small class="skill-tag">no permitida</small>
                      {{/if}}

                      {{#if skill.spent}}
                        <small class="skill-tag skill-tag--spent">gastado {{skill.spent}}</small>
                      {{/if}}
                    </span>
                  </span>

                  <span>{{skill.baseValue}}</span>
                  <span>{{skill.total}}</span>
                  <span>{{skill.max}}</span>
                  <span>{{skill.adjustmentLabel}}</span>

                  <div class="item-actions skill-actions">
                    <button
                      type="button"
                      class="skill-action-btn"
                      data-skill-dec="{{skill.key}}"
                      title="{{skill.minusTooltip}}"
                      {{#unless skill.canDecrease}}disabled{{/unless}}>
                      -
                    </button>

                    <button
                      type="button"
                      class="skill-action-btn"
                      data-skill-inc="{{skill.key}}"
                      title="{{skill.plusTooltip}}"
                      {{#unless skill.canIncrease}}disabled{{/unless}}>
                      +{{skill.cost}}
                    </button>

                    <button
                      type="button"
                      class="skill-action-btn"
                      data-roll-skill="{{skill.key}}"
                      title="{{skill.rollTooltip}}">
                      🎲
                    </button>
                  </div>
                </div>
              {{/each}}
            </div>
          </div>
        </section>

        <section class="card">
          <h2>Competencias de Armas</h2>

          <div class="skills-card-body">
            <div class="skills-table">
              <div class="skills-head skills-grid-extended">
                <span class="skill-head-name">Competencia</span>
                <span>Base</span>
                <span>Total</span>
                <span>Máx.</span>
                <span>Ajuste</span>
                <span>Acciones</span>
              </div>

              {{#each weaponSkills as |skill|}}
                <div class="skills-row skills-grid-extended {{skill.rowClasses}}" title="{{skill.rowTooltip}}">
                  <span class="skill-name">
                    <span class="skill-label">{{skill.label}}</span>
                    <span class="skill-meta">
                      {{#if skill.allowed}}
                        <small class="skill-tag skill-tag--allowed">permitida</small>
                      {{else}}
                        <small class="skill-tag">no permitida</small>
                      {{/if}}

                      {{#if skill.spent}}
                        <small class="skill-tag skill-tag--spent">gastado {{skill.spent}}</small>
                      {{/if}}
                    </span>
                  </span>

                  <span>{{skill.baseValue}}</span>
                  <span>{{skill.total}}</span>
                  <span>{{skill.max}}</span>
                  <span>{{skill.adjustmentLabel}}</span>

                  <div class="item-actions skill-actions">
                    <button
                      type="button"
                      class="skill-action-btn"
                      data-skill-dec="{{skill.key}}"
                      title="{{skill.minusTooltip}}"
                      {{#unless skill.canDecrease}}disabled{{/unless}}>
                      -
                    </button>

                    <button
                      type="button"
                      class="skill-action-btn"
                      data-skill-inc="{{skill.key}}"
                      title="{{#if skill.canIncrease}}{{skill.costTooltip}}{{else}}{{skill.blockReason}}{{/if}}"
                      {{#unless skill.canIncrease}}disabled{{/unless}}>
                      +{{skill.cost}}
                    </button>

                    <button
                      type="button"
                      class="skill-action-btn"
                      data-roll-skill="{{skill.key}}"
                      title="Tirar {{skill.label}}">
                      🎲
                    </button>
                  </div>
                </div>
              {{/each}}
            </div>
          </div>
        </section>
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="combat">
      <div class="sheet-grid sheet-grid--full">
        <section class="card">
          <h2>Combate</h2>

          <div class="combat-grid">
            <label>Acciones actuales
              <input type="number" name="system.combat.actions.current" value="{{system.combat.actions.current}}" />
            </label>

            <label>Acciones máximas
              <input type="number" name="system.combat.actions.max" value="{{system.combat.actions.max}}" disabled />
            </label>

            <label>Dificultad
              <select name="system.combat.difficulty">
                {{#each difficultyOptions as |opt|}}
                  <option value="{{opt.[0]}}" {{#if (eq ../system.combat.difficulty opt.[0])}}selected{{/if}}>{{opt.[1]}}</option>
                {{/each}}
              </select>
            </label>

            <label>Modo de defensa
              <select name="system.combat.defenseMode">
                <option value="skill" {{#if (eq system.combat.defenseMode "skill")}}selected{{/if}}>Competencia</option>
                <option value="weapon" {{#if (eq system.combat.defenseMode "weapon")}}selected{{/if}}>Parada con arma</option>
                <option value="shield" {{#if (eq system.combat.defenseMode "shield")}}selected{{/if}}>Escudo</option>
              </select>
            </label>

            <label class="checkbox-row">Melé (cuerpo a cuerpo)
              <input type="checkbox" name="system.combat.meleeMode" {{#if system.combat.meleeMode}}checked{{/if}} />
            </label>

            <p class="target-hint">
              La defensa usada dependerá del modo elegido: competencia, arma de parada o escudo.
            </p>

            <label>Competencia de defensa
              <select name="system.combat.defenseSkill">
                {{#each defenseSkillOptions as |opt|}}
                  <option value="{{opt.[0]}}" {{#if (eq ../system.combat.defenseSkill opt.[0])}}selected{{/if}}>{{opt.[1]}}</option>
                {{/each}}
              </select>
            </label>

            <label>Arma activa
              <select name="system.combat.activeWeaponId">
                <option value="">--</option>
                {{#each weaponOptions as |opt|}}
                  <option value="{{opt.[0]}}" {{#if (eq ../system.combat.activeWeaponId opt.[0])}}selected{{/if}}>
                    {{opt.[1]}}
                  </option>
                {{/each}}
              </select>
            </label>

            {{#if activeWeaponName}}
              <p class="target-hint">
                Arma usada al atacar: <strong>{{activeWeaponName}}</strong>
                {{#if activeWeaponFallback}}(automática){{/if}}
              </p>
            {{else}}
              <p class="target-hint">No hay arma activa ni equipada.</p>
            {{/if}}

            <div class="button-row combat-actions-row">
              <button type="button" class="primary-action" data-combat-attack="true"><span class="button-icon" aria-hidden="true">⚔️</span>Atacar objetivo</button>
              <button type="button" data-roll-defense="true"><span class="button-icon" aria-hidden="true">🛡️</span>Probar defensa</button>
              <button type="button" data-roll-initiative="true"><span class="button-icon" aria-hidden="true">🎲</span>Tirar iniciativa</button>
              <button type="button" data-consume-action="true"><span class="button-icon" aria-hidden="true">⏳</span>Gastar acción</button>
              <button type="button" data-action="reset-combat-actions"><span class="button-icon" aria-hidden="true">🔄</span>Reiniciar acciones</button>
              <button type="button" data-action="clear-combat-status-effects"><span class="button-icon" aria-hidden="true">🧹</span>Limpiar estados</button>
              <button type="button" data-action="reset-combat-state"><span class="button-icon" aria-hidden="true">🔁</span>Reiniciar combate</button>
            </div>

            <p class="target-hint">
              Flujo de ataque: selecciona arma activa, elige un token objetivo y pulsa <strong>Atacar objetivo</strong>.
            </p>

            <p class="target-hint">
              La defensa depende del modo elegido: <strong>Competencia</strong>, <strong>Parada con arma</strong> o <strong>Escudo</strong>.
            </p>

            <label>Arma de parada
              <select name="system.combat.defenseWeaponId">
                <option value="">--</option>
                {{#each weaponOptions as |opt|}}
                  <option value="{{opt.[0]}}" {{#if (eq ../system.combat.defenseWeaponId opt.[0])}}selected{{/if}}>{{opt.[1]}}</option>
                {{/each}}
              </select>
            </label>

            <label>Escudo
              <select name="system.combat.defenseShieldId">
                <option value="">--</option>
                {{#each shieldOptions as |opt|}}
                  <option value="{{opt.[0]}}" {{#if (eq ../system.combat.defenseShieldId opt.[0])}}selected{{/if}}>{{opt.[1]}}</option>
                {{/each}}
              </select>
            </label>

            <label>Modificador de ataque
              <input type="number" name="system.combat.attackModifier" value="{{system.combat.attackModifier}}" />
            </label>

            <label>Ataque apuntado
              <select name="system.combat.aimLocation">
                {{#each aimLocationOptions as |opt|}}
                  <option value="{{opt.[0]}}" {{#if (eq ../system.combat.aimLocation opt.[0])}}selected{{/if}}>{{opt.[1]}}</option>
                {{/each}}
              </select>
            </label>

            <label>Modificador apuntado
              <input type="number" name="system.combat.aimModifier" value="{{system.combat.aimModifier}}" />
            </label>

            <label>Modificador de defensa
              <input type="number" name="system.combat.defenseModifier" value="{{system.combat.defenseModifier}}" />
            </label>

            <label>Armadura total
              <input type="number" name="system.combat.armorTotal" value="{{system.combat.armorTotal}}" disabled />
            </label>

            <label>Iniciativa
              <input type="number" name="system.combat.initiative" value="{{system.combat.initiative}}" />
            </label>
          </div>

          <div class="card-subsection">
            <h4>Último impacto</h4>
            <p><strong>Localización:</strong> {{lastHitLocationLabel}}</p>
            <p><strong>Armadura absorbida:</strong> {{system.combat.lastArmorAbsorbed}}</p>
            <p><strong>Daño bruto:</strong> {{system.combat.lastRawDamage}}</p>
            <p><strong>Daño final:</strong> {{system.combat.lastFinalDamage}}</p>
          </div>

          <p><strong>Última pifia:</strong> {{system.combat.lastFumble}}</p>
          <p><strong>Último crítico:</strong> {{system.combat.lastCritical}}</p>

          <div class="card-subsection">
            <h4>Penalizadores activos</h4>

            {{#if combatPenaltySummary.length}}
              <div class="status-effects">
                {{#each combatPenaltySummary as |entry|}}
                  <div class="status-effect">
                    <strong>{{entry.label}}</strong>
                    <ul>
                      {{#each entry.effects as |effect|}}
                        <li>{{effect}}</li>
                      {{/each}}
                    </ul>
                  </div>
                {{/each}}
              </div>
            {{else}}
              <p>Sin penalizadores activos.</p>
            {{/if}}
          </div>
        </section>
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="inventory">
      <div class="sheet-grid">
        <section class="card">
          <div class="list-header">
            <h2>Armas</h2>
            <button type="button" class="item-create inventory-create-btn" data-type="weapon">+ Arma</button>
          </div>

          <p class="target-hint">Objetivo actual: {{#if currentTargetName}}{{currentTargetName}}{{else}}ninguno{{/if}}</p>

          {{#each weapons as |item|}}
            <div class="item-row">
              <strong>{{item.name}}</strong>
              <span>{{item.system.skill}}</span>
              <span>{{item.system.damage}}</span>
              <span>
                {{#if item.system.equipped}}Equipada{{else}}No equipada{{/if}}
                {{#if (eq ../system.combat.activeWeaponId item.id)}} · Activa{{/if}}
              </span>
              <div class="item-actions">
                <button type="button" data-roll-damage="{{item.id}}">Daño</button>
                <button type="button" data-set-active-weapon="{{item.id}}">Activar</button>
                <button type="button" data-toggle-equipped="{{item.id}}">Equipar</button>
                <button type="button" class="item-edit" data-item-id="{{item.id}}">Editar</button>
                <button type="button" class="item-delete" data-item-id="{{item.id}}">🗑</button>
              </div>
            </div>
          {{/each}}
        </section>

        <section class="card">
          <div class="list-header">
            <h2>Escudos</h2>
            <button type="button" class="item-create inventory-create-btn" data-type="shield">+ Escudo</button>
          </div>

          {{#each shields as |item|}}
            <div class="item-row">
              <strong>{{item.name}}</strong>
              <span>Prot: {{item.system.protection}}</span>
              <span>Def: {{item.system.defenseBonus}}</span>
              <span>{{#if item.system.equipped}}Equipado{{else}}No{{/if}}</span>
              <div class="item-actions">
                <button type="button" data-toggle-equipped="{{item.id}}">Equipar</button>
                <button type="button" class="item-edit" data-item-id="{{item.id}}">Editar</button>
                <button type="button" class="item-delete" data-item-id="{{item.id}}">🗑</button>
              </div>
            </div>
          {{/each}}
        </section>

        <section class="card">
          <div class="list-header">
            <h2>Armaduras</h2>
            <button type="button" class="item-create inventory-create-btn" data-type="armor">+ Armadura</button>
          </div>

          {{#each armors as |item|}}
            <div class="item-row">
              <strong>{{item.name}}</strong>
              <span>Prot: {{item.system.protection}}</span>
              <span>{{item.system.location}}</span>
              <span>{{#if item.system.equipped}}Equipada{{else}}No{{/if}}</span>
              <div class="item-actions">
                <button type="button" data-toggle-equipped="{{item.id}}">Equipar</button>
                <button type="button" class="item-edit" data-item-id="{{item.id}}">Editar</button>
                <button type="button" class="item-delete" data-item-id="{{item.id}}">🗑</button>
              </div>
            </div>
          {{/each}}
        </section>

        <section class="card">
          <div class="list-header">
            <h2>Hechizos</h2>
            <button type="button" class="item-create inventory-create-btn" data-type="spell">+ Hechizo</button>
          </div>

          {{#each spells as |item|}}
            <div class="item-row">
              <strong>{{item.name}}</strong>
              <span>{{item.system.skill}}</span>
              <span>{{item.system.cost}}</span>
              <span>{{item.system.difficultyMod}}</span>
              <div class="item-actions">
                <button type="button" data-cast-spell="{{item.id}}">Lanzar</button>
                <button type="button" class="item-edit" data-item-id="{{item.id}}">Editar</button>
                <button type="button" class="item-delete" data-item-id="{{item.id}}">🗑</button>
              </div>
            </div>
          {{/each}}
        </section>

        <section class="card">
          <div class="list-header">
            <h2>Rituales</h2>
            <button type="button" class="item-create inventory-create-btn" data-type="ritual">+ Ritual</button>
          </div>

          {{#each rituals as |item|}}
            <div class="item-row">
              <strong>{{item.name}}</strong>
              <span>{{item.system.skill}}</span>
              <span>{{item.system.cost}}</span>
              <span>{{item.system.difficultyMod}}</span>
              <div class="item-actions">
                <button type="button" data-invoke-ritual="{{item.id}}">Invocar</button>
                <button type="button" class="item-edit" data-item-id="{{item.id}}">Editar</button>
                <button type="button" class="item-delete" data-item-id="{{item.id}}">🗑</button>
              </div>
            </div>
          {{/each}}
        </section>

        <section class="card">
          <div class="list-header">
            <h2>Objetos</h2>
            <button type="button" class="item-create inventory-create-btn" data-type="gear">+ Objeto</button>
          </div>

          {{#each gear as |item|}}
            <div class="item-row">
              <strong>{{item.name}}</strong>
              <span>Cant: {{item.system.quantity}}</span>
              <span>{{#if item.system.equipped}}Equipado{{else}}No{{/if}}</span>
              <div class="item-actions">
                <button type="button" data-toggle-equipped="{{item.id}}">Equipar</button>
                <button type="button" class="item-edit" data-item-id="{{item.id}}">Editar</button>
                <button type="button" class="item-delete" data-item-id="{{item.id}}">🗑</button>
              </div>
            </div>
          {{/each}}
        </section>
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="magic">
      <div class="sheet-grid">
        <section class="card">
          <h2>Datos personales</h2>
          <div class="secondary-grid">
            <label>Profesión paterna
              <input type="text" value="{{selectedFatherProfessionLabel}}" disabled />
            </label>

            <label>Altura
              <input type="text" name="system.bio.height" value="{{system.bio.height}}" />
            </label>

            <label>Peso
              <input type="text" name="system.bio.weight" value="{{system.bio.weight}}" />
            </label>
          </div>
        </section>

        <section class="card">
          <h2>Economía</h2>
          <label>Dinero <textarea name="system.economy.money">{{system.economy.money}}</textarea></label>
          <label>Ingreso mensual <textarea name="system.economy.monthlyIncome">{{system.economy.monthlyIncome}}</textarea></label>
          <label>Gasto semanal <textarea name="system.economy.weeklyExpense">{{system.economy.weeklyExpense}}</textarea></label>
        </section>

        <section class="card">
          <h2>Posesiones</h2>
          <textarea name="system.inventory.possessions">{{system.inventory.possessions}}</textarea>
        </section>

        <section class="card">
          <h2>Equipo transportado</h2>
          <textarea name="system.inventory.carriedEquipment">{{system.inventory.carriedEquipment}}</textarea>
        </section>

        <section class="card">
          <h2>Hechizos y notas</h2>
          <textarea name="system.magic.spellsNotes">{{system.magic.spellsNotes}}</textarea>
        </section>

        <section class="card">
          <h2>Rituales y notas</h2>
          <textarea name="system.magic.ritualsNotes">{{system.magic.ritualsNotes}}</textarea>
        </section>

        <section class="card">
          <h2>Descripción</h2>
          <textarea name="system.bio.description">{{system.bio.description}}</textarea>
        </section>

        <section class="card">
          <h2>Historia</h2>
          <textarea name="system.bio.history">{{system.bio.history}}</textarea>
        </section>
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="reference">
      <div class="sheet-grid">
        <section class="card">
          <h2>Dificultades activas</h2>
          <ul>
            <li>Muy fácil: +40</li>
            <li>Fácil: +20</li>
            <li>Normal: 0</li>
            <li>Difícil: -20</li>
            <li>Muy difícil: -40</li>
          </ul>
        </section>

        <section class="card">
          <h2>Flujo de combate</h2>
          <p><strong>1.</strong> Equipa un arma.</p>
          <p><strong>2.</strong> Selecciona arma activa en la pestaña Combate.</p>
          <p><strong>3.</strong> Selecciona un token objetivo en la escena.</p>
          <p><strong>4.</strong> Pulsa <strong>Atacar objetivo</strong>.</p>
          <p><strong>5.</strong> El sistema resuelve ataque, defensa, localización, armadura y daño.</p>
        </section>

        <section class="card">
          <h2>Defensa</h2>
          <p><strong>Competencia:</strong> usa la skill elegida en “Competencia de defensa”.</p>
          <p><strong>Parada con arma:</strong> requiere arma seleccionada, equipada y defensiva.</p>
          <p><strong>Escudo:</strong> requiere escudo seleccionado y equipado.</p>
          <p><strong>Esquivar:</strong> puede verse penalizado por estados como pierna inutilizada.</p>
        </section>

        <section class="card">
          <h2>Creación RAW</h2>
          <p><strong>1.</strong> Elige reino, grupo étnico y clase social.</p>
          <p><strong>2.</strong> Revisa las profesiones disponibles.</p>
          <p><strong>3.</strong> Genera características si aún no lo has hecho.</p>
          <p><strong>4.</strong> Selecciona una profesión RAW.</p>
          <p><strong>5.</strong> Pulsa <strong>Aplicar profesión RAW</strong> para asignar puntos, equipo y dinero base.</p>
        </section>
      </div>
    </div>
  </section>
</form>
