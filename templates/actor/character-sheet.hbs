        <section class="card">
          <h2>Dificultades</h2>
          <ul>
            <li>Infalible: +60</li>
            <li>Muy fácil: +40</li>
            <li>Fácil: +20</li>
            <li>Normal: 0</li>
            <li>Difícil: -20</li>
            <li>Muy difícil: -40</li>
            <li>Imposible: -60</li>
          </ul>
        </section>

        <section class="card">
          <h2>Notas rápidas</h2>
          <p>v0.3.0 RAW: las competencias usan Base + Invertido = Total.</p>
